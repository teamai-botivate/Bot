# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URI.
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URI=postgresql+psycopg2://user:password@localhost:5432/yourdb

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LLM Configuration (optional – defaults shown) ────────────────────────────
LLM_MODEL=gpt-4.1
LLM_TEMPERATURE=0

# ── CORS (optional – defaults to * which allows all origins) ─────────────────
# Comma-separated list of allowed frontend origins.
# Example: ALLOWED_ORIGINS=http://localhost:5500,https://yourapp.com
ALLOWED_ORIGINS=*
